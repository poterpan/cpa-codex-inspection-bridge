# If the compatible CPA service runs on the Docker host, use http://host.docker.internal:3000 inside Docker.
# ENV values seed the SQLite config only when data/inspection_bridge.db has no settings yet.
CPA_BASE_URL=http://127.0.0.1:3000
CPA_MANAGEMENT_KEY=

INSPECTION_INTERVAL_MINUTES=240
INSPECTION_CONCURRENCY=4
INSPECTION_TIMEOUT_SECONDS=20
QUOTA_THRESHOLD=100
AUTO_START=true

NOTIFY_ON_SUCCESS=true
NOTIFY_ON_ABNORMAL=true

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org

BARK_ENABLED=false
BARK_SERVER=https://api.day.app
BARK_DEVICE_KEY=
BARK_GROUP=CPA Codex Inspection
